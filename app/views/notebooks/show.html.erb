<div class="container mx-auto p-4">
 <header class="flex items-center justify-between bg-white shadow-md p-2 rounded">
		<div class="flex">
			<input type="text" placeholder="Search..." class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
		</div>
		<div>
    	<%= link_to 'Back to Notebook', notebooks_path, class: 'bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-opacity-50 ml-2' %>
    </div>
  </header>
  <div class="max-w-sm mx-auto mt-4">
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <div class="p-6">
        <h2 class="text-xl font-semibold text-gray-800"><%= @notebook.title%></h2>
        <p class="mt-2 text-gray-600"><%= @notebook.description%></p>
        <div class="mt-4">
          <%= link_to 'Edit Notebook', edit_notebook_path(@notebook), class: 'bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600' %>
          <%= link_to 'Delete', notebook_path(@notebook),data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure?" }, class: 'bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600' %>
        </div>
      </div>
    </div>
  </div>
  <div class="max-w-sm mx-auto mt-4">
    <% if @notebook.pages.blank? %>
      <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-3 rounded relative mb-4" role="alert">
        <strong class="font-bold">Info!</strong>
        <span class="block sm:inline">No pages found.</span>
      </div>
    <% else %>
      <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <div class="p-6">
        <% @notebook.pages.each do |page| %>
          <h2 class="text-xl font-semibold text-gray-800"><%= page.title%></h2>
          <p class="mt-2 text-gray-600"><%= page.context%></p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
