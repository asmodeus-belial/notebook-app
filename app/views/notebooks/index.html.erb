<div class="container mx-auto p-4">
  <header class="flex items-center justify-between bg-white shadow-md p-4 rounded">
		<div class="flex">
				<input type="text" placeholder="Search..." class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
		</div>
		<div>
    	<%= link_to 'New Notebook', new_notebook_path, class: 'bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600' %>
    </div>
  </header>
	<div class="overflow-x-auto">
		<table class="min-w-full bg-white border border-gray-300 rounded-lg shadow-md">
			<thead>
				<tr class= "bg-gray-200 text-gray-600 uppercase text-sm leading-normal">
					<th py-3 px-6 text-left>ID</th>
					<th py-3 px-6 text-left>Title</th>
					<th py-3 px-6 text-left>Description</th>
					<th py-3 px-6 text-left>Actions</th>
				</tr>
  		</thead>
			<% @notebooks.each do |notebook| %>
				<tbody class="text-gray-600 text-sm font-light mt-6">
					<tr class="border-b border-gray-300 hover:bg-gray-100">
						<td class="py-3 px-6"><%= notebook.id %></td>
						<td class="py-3 px-6"><%= notebook.title %></td>
						<td class="py-3 px-6"><%= notebook.description %></td>
						<td class="py-3 px-6">
							<%= link_to 'View', notebook_path(notebook), class: 'bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600' %>
						</td>
						<td class="py-3 px-6">
							<%= link_to 'Edit Notebook', edit_notebook_path(notebook), class: 'bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600' %>
						</td>
						<td class="py-3 px-6">
							<%= link_to 'Delete', notebook_path(notebook), data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure?" }, class: 'bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-opacity-50' %>
						</td>
					</tr>
				</tbody>
			<% end %>
			</table>
	</div>
</div>